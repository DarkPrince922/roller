# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=123456,7891011

# --- MWS API ---
# Gateway base URL. Confirmed via https://docs.cloud.mts.ru/api/ : https://gateway.cloud.mts.ru
MWS_API_BASE=https://gateway.cloud.mts.ru
# Long-lived service-account Bearer token (see https://docs.cloud.mts.ru/api/auth.html).
# This is the primary supported auth mode. See app/mws_client.py for the TODO-marked
# auto-refresh-via-/iam/v2/tokens code path, disabled by default until the exact
# request body is confirmed against the live OpenAPI spec.
MWS_API_TOKEN=
MWS_PROJECT_ID=
# Network this IP service is bound to (parentBinding.targetId in the create body).
MWS_NETWORK_ID=
MWS_REGION=msk
# platform.regionCode
MWS_REGION_CODE=msk
# top-level zoneCode (e.g. msk-avntg) -- TODO confirm exact zone codes for your region via OpenAPI/console
MWS_ZONE_CODE=
MWS_IP_QUOTA=5

# --- SOCKS5 proxy (host:port:user:pass, or host:port without auth) ---
PROXY=

# --- Hunt engine ---
HUNT_STRATEGY=release_immediately
TARGET_CIDRS=
TARGET_ASNS=
TARGET_COUNT=1
MAX_ATTEMPTS=500
MAX_RUNTIME_MIN=120
MAX_BUDGET=0
RATE_LIMIT_DELAY_SEC=2
# Estimated cost (currency units) per reserved-unattached IP per hour, used only
# for the /status budget estimate -- TODO confirm real billing unit with MWS.
ESTIMATED_COST_PER_IP_HOUR=0

# --- ASN resolution ---
IP2ASN_DB_PATH=/data/ip2asn-v4.tsv

# --- Storage / logging ---
DB_PATH=/data/state.sqlite
LOG_LEVEL=INFO
