# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=123456,7891011

# --- MWS API ---
# VPC service base URL -- public IP addresses are the "externalAddress" resource here
# (GET/POST/DELETE /vpc/v1/projects/{project}/externalAddresses[/...]).
MWS_VPC_BASE=https://vpc.mwsapis.ru
# IAM gateway base URL (service-account token issuance). Different host from
# MWS_VPC_BASE -- see app/mws_client.py.
MWS_IAM_BASE=https://iam.mwsapis.ru
# Recommended auth mode: path to the authorized-key JSON file downloaded from the
# console (IAM / Сервисные аккаунты -> выбери сервисный аккаунт -> создать
# авторизованный ключ -> скачать JSON). The bot exchanges this key for short-lived
# IAM access tokens automatically and refreshes them before they expire.
# Put the file in ./data (mounted to /data by docker-compose) and point here, e.g.:
MWS_SA_KEY_FILE=/data/mws-authorized-key.json
# Fallback auth mode: a ready-made IAM access token, used as-is (Authorization: Bearer
# <value>) if MWS_SA_KEY_FILE is not set. NOT auto-refreshed -- it will expire (IAM
# access tokens are short-lived, ~1h), so MWS_SA_KEY_FILE is preferred for anything
# long-running. Leave empty if using MWS_SA_KEY_FILE.
MWS_API_TOKEN=
MWS_PROJECT_ID=
# Optional NAT gateway ref for the externalAddress's spec.natGateway (e.g.
# "myNatGateway" or "vpc/projects/<project>/natGateways/myNatGateway"). Leave empty
# to use the account's default internet gateway (natGateways/internet-gateway).
MWS_NAT_GATEWAY=
# Display/storage-only label, not sent to the API (externalAddress has no
# region/zone scoping at the API level -- only the project).
MWS_REGION=msk
MWS_IP_QUOTA=5

# --- SOCKS5 proxy (host:port:user:pass, or host:port without auth) ---
PROXY=

# --- Hunt engine ---
HUNT_STRATEGY=release_immediately
TARGET_CIDRS=
TARGET_ASNS=
TARGET_COUNT=1
MAX_ATTEMPTS=500
MAX_RUNTIME_MIN=120
MAX_BUDGET=0
RATE_LIMIT_DELAY_SEC=2
# Estimated cost (currency units) per reserved-unattached IP per hour, used only
# for the /status budget estimate -- TODO confirm real billing unit with MWS.
ESTIMATED_COST_PER_IP_HOUR=0

# --- ASN resolution ---
IP2ASN_DB_PATH=/data/ip2asn-v4.tsv

# --- Storage / logging ---
DB_PATH=/data/state.sqlite
LOG_LEVEL=INFO
